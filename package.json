{
  "name": "ordinary-project",
  "version": "1.0.0",
  "private": true,
  "description": "",
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "tsx watch apps/backend/src/index.ts",
    "dev:frontend": "vite --config apps/frontend/vite.config.ts",
    "build": "tsc -p apps/backend/tsconfig.json",
    "build:frontend": "tsc -b apps/frontend && vite build --config apps/frontend/vite.config.ts",
    "start": "node apps/backend/dist/index.js",
    "typecheck": "tsc -p apps/backend/tsconfig.json --noEmit",
    "typecheck:frontend": "tsc -b apps/frontend",
    "lint": "eslint --config apps/frontend/eslint.config.js",
    "preview:frontend": "vite preview --config apps/frontend/vite.config.ts",
    "db:up": "docker compose -f apps/backend/docker-compose.yaml --env-file apps/backend/.env up -d",
    "db:down": "docker compose -f apps/backend/docker-compose.yaml down",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate:create": "tsx apps/backend/src/db/migrate.ts",
    "migrate:up": "tsx apps/backend/src/db/migrationRunner.ts up",
    "migrate:down": "tsx apps/backend/src/db/migrationRunner.ts down"
  },
  "keywords": [],
  "author": "Abhishek",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.14.1",
    "pg-promise": "^12.6.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
