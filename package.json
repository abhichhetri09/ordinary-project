{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch apps/backend/src/index.ts",
    "build": "tsc -p apps/backend/tsconfig.json",
    "start": "node apps/backend/dist/index.js",
    "typecheck": "tsc -p apps/backend/tsconfig.json --noEmit",
    "db:up": "docker compose -f apps/backend/docker-compose.yaml --env-file apps/backend/.env up -d",
    "db:down": "docker compose -f apps/backend/docker-compose.yaml down",
    "test": "echo \"Error: no test specified\" && exit 1",
    "migrate:create": "tsx apps/backend/src/db/migrate.ts",
    "migrate:up": "tsx apps/backend/src/db/migrationRunner.ts up",
    "migrate:down": "tsx apps/backend/src/db/migrationRunner.ts down"
  },
  "keywords": [],
  "author": "Abhishek",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "nodemon": "^3.1.14",
    "pg": "^8.14.1",
    "pg-promise": "^12.6.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.2"
  }
}
